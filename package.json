{
  "name": "jw-meeting-player",
  "displayName": "JW Meeting Player",
  "description": "Player for controlling media display/share on Jehova's Witnesses meetings",
  "private": true,
  "version": "0.25.1",
  "author": {
    "name": "Gustavo Miguel",
    "email": "gu.rmiguel@gmail.com"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build-ci": "tsc && vite build",
    "build": "tsc && node-gyp build && vite build && electron-builder",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "script": "ts-node --transpile-only --esm -P tsconfig.node.json electron/run-script.ts",
    "postinstall": "patch-package && electron-builder install-app-deps && node-gyp rebuild"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.0.18",
    "@reduxjs/toolkit": "^2.11.2",
    "@sindresorhus/transliterate": "^1.6.0",
    "bindings": "^1.5.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "electron-log": "^5.3.3",
    "electron-settings": "^4.0.4",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.6.2",
    "encoding": "^0.1.13",
    "file-type": "^22.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "focus-trap-react": "^10.2.3",
    "framer-motion": "^11.0.3",
    "jsdom": "^22.1.0",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "nanoid": "^3.3.7",
    "node-addon-api": "^8.3.1",
    "patch-package": "^8.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.2.0",
    "react-transition-group": "^4.4.5",
    "redux": "^5.0.1",
    "sonner": "^1.4.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "tasklist": "^5.0.0",
    "undici": "^8.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/ffbinaries": "^1.1.4",
    "@types/fluent-ffmpeg": "^2.1.23",
    "@types/jsdom": "^21.1.4",
    "@types/jszip": "^3.4.1",
    "@types/lodash": "^4.14.195",
    "@types/lodash-es": "^4.17.8",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.10",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.14",
    "browserslist": "^4.22.3",
    "electron": "^35.1.1",
    "electron-builder": "^26.0.12",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.3.5",
    "node-abi": "^4.2.0",
    "node-gyp": "^11.1.0",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-svgr": "^4.3.0"
  },
  "main": "dist-electron/main.js"
}
